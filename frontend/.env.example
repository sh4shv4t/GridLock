# Copy this file to .env.local (gitignored) and fill in your token.
# Create React App only exposes vars prefixed REACT_APP_, read at build/start time.
# Restart `npm start` after changing this.

# Mappls (MapmyIndia) Web Maps SDK token — required for the map to render.
# Regenerate at https://apis.mappls.com (tokens expire ~24h).
REACT_APP_MAPPLS_TOKEN=
